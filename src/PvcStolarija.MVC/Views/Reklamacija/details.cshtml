@model PvcStolarija.DAL.Models.Reklamacija
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Detalji Reklamacije"; var kupac=Model.KupacReklamacije.FirstOrDefault()?.Kupac; }
<div><div class="row justify-content-center"><div class="col-lg-10">
    <div class="card shadow-sm"><div class="card-header bg-info text-white"><h4 class="mb-0">Detalji Reklamacije #@Model.Id</h4></div>
    <div class="card-body">
        <div class="text-center mb-4">
            <span class="badge @(Model.Resena?"bg-success":"bg-danger") fs-5 px-4 py-2">@(Model.Resena?"✓ REŠENA":"✗ U TOKU")</span>
        </div>
        <div class="row mb-4">
            <div class="col-md-4 mb-3"><div class="card bg-light"><div class="card-body"><h6 class="text-muted mb-1">Datum</h6><h5>@Model.Datum.ToString("dd.MM.yyyy")</h5></div></div></div>
            <div class="col-md-4 mb-3"><div class="card bg-light"><div class="card-body"><h6 class="text-muted mb-1">Tip Reklamacije</h6><h5><span class="badge @(Model.TipReklamacije==TipReklamacije.Pisana?"bg-info":"bg-warning text-dark") fs-6">@(Model.TipReklamacije==TipReklamacije.Pisana?"📝 Pisana":"🔧 Terenska")</span></h5></div></div></div>
            <div class="col-md-4 mb-3"><div class="card bg-light"><div class="card-body"><h6 class="text-muted mb-1">Prioritet</h6><h5 class="@(Model.Resena?"text-success":"text-danger")">@Model.Prioritet / 100</h5></div></div></div>
        </div>
        <hr />
        <h5 class="mb-3">Učesnici</h5>
        <div class="row mb-4">
            <div class="col-md-6 mb-3"><div class="card h-100"><div class="card-body text-center">
                @if(kupac!=null){ <h6 class="card-subtitle mb-2 text-muted">👤 Kupac</h6><h5>@kupac.Ime @kupac.Prezime</h5><p class="small text-muted">@kupac.JMBG</p> }
                else { <p class="text-muted">N/A</p> }
            </div></div></div>
            <div class="col-md-6 mb-3"><div class="card h-100"><div class="card-body text-center">
                @if(Model.Radnik!=null){ <h6 class="card-subtitle mb-2 text-muted">👷 Odgovorni Radnik</h6><h5>@Model.Radnik.Ime @Model.Radnik.Prezime</h5> }
                else { <p class="text-muted">N/A</p> }
            </div></div></div>
        </div>
        @if(Model.TipReklamacije==TipReklamacije.Terenska&&Model.ReklamacijaProizvodi.Any()){
        <hr /><h5 class="mb-3">🪟 Reklamirani Proizvodi <span class="badge bg-secondary">@Model.ReklamacijaProizvodi.Count</span></h5>
        <div class="row">
            @foreach(var rp in Model.ReklamacijaProizvodi){
            var p=rp.Proizvod; var slika=p.Slike?.FirstOrDefault()?.PutanjaDoSlike;
            <div class="col-md-4 mb-3"><div class="card h-100 shadow-sm">
                @if(!string.IsNullOrEmpty(slika)){<img src="@slika" class="card-img-top" style="height:180px;object-fit:cover;" />}
                else{<div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height:180px;"><span style="font-size:3rem;">🪟</span></div>}
                <div class="card-body"><h6>@p.Naziv @p.Model</h6><p class="small text-muted">@p.Sifra</p></div>
            </div></div>
            }
        </div>
        }
        <hr /><div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Izmeni</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Obriši</a>
            <a asp-action="Index" class="btn btn-secondary">Nazad</a>
        </div>
    </div></div>
</div></div></div>
