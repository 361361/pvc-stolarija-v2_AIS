@model PvcStolarija.MVC.ViewModels.Reklamacija.ReklamacijaViewModel
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Obriši Reklamaciju"; }

<div class="page-header" style="background:linear-gradient(135deg,#dc3545,#b02a37)">
    <h2><i class="bi bi-trash me-2"></i>Obriši Reklamaciju</h2>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-2"></i><strong>Upozorenje!</strong> Ova akcija je trajna.</div>
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white"><h6 class="mb-0">Podaci reklamacije koja se briše</h6></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Datum</dt><dd class="col-sm-8">@Model.Datum.ToString("dd.MM.yyyy")</dd>
                    <dt class="col-sm-4 text-muted">Tip</dt><dd class="col-sm-8">@Model.TipReklamacije</dd>
                    <dt class="col-sm-4 text-muted">Prioritet</dt><dd class="col-sm-8 @(Model.Resena ? "text-success" : "text-danger") fw-bold">@Model.Prioritet/100</dd>
                    <dt class="col-sm-4 text-muted">Kupac</dt><dd class="col-sm-8">@(Model.KupacImePrezime ?? "—")</dd>
                    <dt class="col-sm-4 text-muted">Radnik</dt><dd class="col-sm-8">@(Model.RadnikImePrezime ?? "—")</dd>
                </dl>
            </div>
        </div>
        <form asp-action="Delete" method="post" class="mt-3">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Potvrdi Brisanje</button>
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x me-1"></i>Odustani</a>
            </div>
        </form>
    </div>
</div>
