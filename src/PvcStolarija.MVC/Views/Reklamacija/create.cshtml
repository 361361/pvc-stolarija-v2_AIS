@model PvcStolarija.MVC.ViewModels.Reklamacija.ReklamacijaViewModel
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Nova Reklamacija"; }

<div class="page-header">
    <h2><i class="bi bi-exclamation-triangle me-2"></i>Nova Reklamacija</h2>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="TipReklamacije" class="form-label">Tip Reklamacije <span class="text-danger">*</span></label>
                            <select asp-for="TipReklamacije" class="form-select" id="tipSelect"
                                    asp-items="Html.GetEnumSelectList<TipReklamacije>()">
                                <option value="">-- Izaberi --</option>
                            </select>
                            <span asp-validation-for="TipReklamacije" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Datum" class="form-label">Datum <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-calendar"></i></span>
                                <input asp-for="Datum" class="form-control" type="datetime-local" />
                            </div>
                            <span asp-validation-for="Datum" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Prioritet" class="form-label">Prioritet (0–100) <span class="text-danger">*</span></label>
                            <input asp-for="Prioritet" class="form-control" type="number" min="0" max="100" id="prioritetInput" />
                            <div id="statusBadge" class="mt-1"></div>
                            <span asp-validation-for="Prioritet" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RadnikId" class="form-label">Odgovorni Radnik <span class="text-danger">*</span></label>
                            <select asp-for="RadnikId" class="form-select">
                                <option value="">-- Izaberi Radnika --</option>
                                @foreach (var r in Model.RadniciLista)
                                {
                                    <option value="@r.Id">@r.ImePrezime</option>
                                }
                            </select>
                            <span asp-validation-for="RadnikId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="KupacId" class="form-label">Kupac <span class="text-danger">*</span></label>
                            <select asp-for="KupacId" class="form-select">
                                <option value="">-- Izaberi Kupca --</option>
                                @foreach (var k in Model.KupciLista)
                                {
                                    <option value="@k.Id">@k.ImePrezime (@k.JMBG)</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div id="proizvodiSection" style="display:none;">
                        <hr />
                        <h6 class="fw-semibold mb-2 text-muted"><i class="bi bi-grid me-1"></i>Reklamirani Proizvodi <span class="text-danger">*</span></h6>
                        <div class="alert alert-info small py-2"><i class="bi bi-info-circle me-1"></i>Terenska reklamacija mora imati bar jedan proizvod.</div>
                        <div class="row g-2">
                            @foreach (var p in Model.ProizvodiLista)
                            {
                                <div class="col-md-6">
                                    <div class="card h-100">
                                        <div class="card-body p-2">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="SelectedProizvodiIds" value="@p.Id" id="p_@p.Id" />
                                                <label class="form-check-label" for="p_@p.Id">
                                                    <strong>@p.Naziv</strong><br />
                                                    <small class="text-muted">@p.Sifra</small>
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <hr />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Sačuvaj</button>
                        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x me-1"></i>Otkaži</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function toggle() {
            const t = document.getElementById('tipSelect').value;
            document.getElementById('proizvodiSection').style.display = t === '1' ? 'block' : 'none';
        }
        function updateStatus() {
            const p = parseInt(document.getElementById('prioritetInput').value) || 0;
            document.getElementById('statusBadge').innerHTML =
                p >= 51 ? '<span class="badge bg-success">Rešena</span>' : '<span class="badge bg-danger">U toku</span>';
        }
        document.getElementById('tipSelect').addEventListener('change', toggle);
        document.getElementById('prioritetInput').addEventListener('input', updateStatus);
        toggle(); updateStatus();
    </script>
}
