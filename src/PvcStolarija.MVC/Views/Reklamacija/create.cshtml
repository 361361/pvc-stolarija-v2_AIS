@model PvcStolarija.DAL.Models.Reklamacija
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Nova Reklamacija"; }
<div><div class="row justify-content-center"><div class="col-lg-8">
    <div class="card shadow-sm"><div class="card-header bg-primary text-white"><h4 class="mb-0">⚠️ Nova Reklamacija</h4></div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row">
                <div class="col-md-6 mb-3"><label asp-for="TipReklamacije" class="form-label">Tip Reklamacije</label>
                    <select asp-for="TipReklamacije" class="form-select" id="tipReklamacije" required>
                        <option value="0">📝 Pisana</option>
                        <option value="1">🔧 Terenska</option>
                    </select></div>
                <div class="col-md-6 mb-3"><label asp-for="Datum" class="form-label">Datum</label><input asp-for="Datum" type="datetime-local" class="form-control" required /></div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3"><label asp-for="Prioritet" class="form-label">Prioritet (0–100)</label>
                    <input asp-for="Prioritet" type="number" min="0" max="100" class="form-control" id="prioritetInput" required />
                    <div id="statusBadge" class="mt-2"></div></div>
                <div class="col-md-6 mb-3"><label class="form-label">Kupac</label>
                    <select name="kupacId" class="form-select" required>
                        <option value="">-- Izaberi kupca --</option>
                        @foreach(var k in ViewBag.Kupci){<option value="@k.Id">@k.Ime @k.Prezime (@k.JMBG)</option>}
                    </select></div>
            </div>
            <div class="mb-3"><label asp-for="RadnikId" class="form-label">Odgovorni Radnik</label>
                <select asp-for="RadnikId" class="form-select" required>
                    <option value="">-- Izaberi radnika --</option>
                    @foreach(var r in ViewBag.RadniciLista){<option value="@r.Id">@r.Ime @r.Prezime</option>}
                </select></div>
            <div id="proizvodiSection" class="mb-3" style="display:none;">
                <label class="form-label">Proizvodi <span class="text-danger">*</span></label>
                <div class="alert alert-info small">Terenska reklamacija mora imati bar jedan proizvod!</div>
                <div class="row">
                    @foreach(var p in ViewBag.ProizvodiLista){
                    <div class="col-md-6 mb-2"><div class="card h-100"><div class="card-body p-2"><div class="form-check">
                        <input class="form-check-input" type="checkbox" name="selectedProizvodi" value="@p.Id" id="proizvod_@p.Id" />
                        <label class="form-check-label" for="proizvod_@p.Id"><strong>@p.Naziv @p.Model</strong><br/><small class="text-muted">@p.Sifra</small></label>
                    </div></div></div></div>
                    }
                </div>
            </div>
            <hr /><div class="d-flex gap-2"><button type="submit" class="btn btn-success">Sačuvaj</button><a asp-action="Index" class="btn btn-secondary">Otkaži</a></div>
        </form>
    </div></div>
</div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" />
<script>
function toggleProizvodi(){const t=document.getElementById('tipReklamacije').value;document.getElementById('proizvodiSection').style.display=t==='1'?'block':'none';}
function updateStatus(){const p=parseInt(document.getElementById('prioritetInput').value)||0;const b=document.getElementById('statusBadge');b.innerHTML=p>=51?'<span class="badge bg-success">✓ Rešena</span>':'<span class="badge bg-danger">✗ U toku</span>';}
document.getElementById('tipReklamacije').addEventListener('change',toggleProizvodi);
document.getElementById('prioritetInput').addEventListener('input',updateStatus);
toggleProizvodi();updateStatus();
</script> }
