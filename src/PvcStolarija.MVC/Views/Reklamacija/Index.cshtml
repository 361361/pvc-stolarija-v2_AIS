@model IEnumerable<PvcStolarija.DAL.Models.Reklamacija>
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Reklamacije"; }

    <div class="page-header mb-0"><div>
        <h2><i class="bi bi-exclamation-triangle me-2"></i>Reklamacije</h2>
        <a asp-action="Create" class="btn btn-primary">+ Nova Reklamacija</a>
    </div>
    <div class="card shadow-sm"><div class="card-body">
        @if(!Model.Any()){
            <div class="text-center py-5"><p class="text-muted">Nema reklamacija.</p></div>
        } else {
        <div class="table-responsive"><table class="table table-hover align-middle"><thead class="table-dark">
            <tr><th>Datum</th><th>Tip</th><th>Kupac</th><th>Radnik</th><th>Prioritet</th><th>Status</th><th>Proizvodi</th><th>Akcije</th></tr>
        </thead><tbody>
            @foreach(var r in Model){
            var kupac=r.KupacReklamacije.FirstOrDefault()?.Kupac;
            <tr>
                <td>@r.Datum.ToString("dd.MM.yyyy")</td>
                <td><span class="badge @(r.TipReklamacije==TipReklamacije.Pisana?"bg-info":"bg-warning text-dark")">@(r.TipReklamacije==TipReklamacije.Pisana?"📝 Pisana":"🔧 Terenska")</span></td>
                <td>@(kupac!=null?$"{kupac.Ime} {kupac.Prezime}":"N/A")</td>
                <td>@(r.Radnik!=null?$"{r.Radnik.Ime} {r.Radnik.Prezime}":"N/A")</td>
                <td><strong class="@(r.Resena?"text-success":"text-danger")">@r.Prioritet</strong><span class="text-muted">/100</span></td>
                <td><span class="badge @(r.Resena?"bg-success":"bg-danger")">@(r.Resena?"✓ Rešena":"✗ U toku")</span></td>
                <td>@if(r.TipReklamacije==TipReklamacije.Terenska){<span class="badge bg-secondary">@r.ReklamacijaProizvodi.Count</span>}else{<span class="text-muted">-</span>}</td>
                <td><div class="d-flex gap-1">
                    <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-info btn-sm text-white">Detalji</a>
                    <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-warning btn-sm">Izmeni</a>
                    <a asp-action="Delete" asp-route-id="@r.Id" class="btn btn-danger btn-sm">Obriši</a>
                </div></td>
            </tr>
            }
        </tbody></table></div>
        }
    </div></div>
</div>
