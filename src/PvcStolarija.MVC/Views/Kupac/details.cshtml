@model PvcStolarija.DAL.Models.Kupac
@{ ViewData["Title"] = "Detalji Kupca"; }
<div>
    <div class="page-header mb-4"><h2>Detalji Kupca</h1><hr />
    <div class="row mb-4">
        <div class="col-md-3 text-center">
            @if (!string.IsNullOrEmpty(Model.ProfilnaSlika)) { <img src="@Model.ProfilnaSlika" class="img-fluid img-thumbnail" style="max-width:250px;border-radius:8px;" /> }
            else { <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="width:250px;height:250px;margin:0 auto;font-size:72px;border-radius:8px;">@Model.Ime.Substring(0,1)@Model.Prezime.Substring(0,1)</div> }
            <h5 class="mt-3">@Model.Ime @Model.Prezime</h5>
        </div>
        <div class="col-md-9"><div class="card"><div class="card-header bg-primary text-white"><h5 class="mb-0">Informacije o Kupcu</h5></div>
        <div class="card-body"><dl class="row mb-0">
            <dt class="col-sm-4">Ime</dt><dd class="col-sm-8">@Model.Ime</dd>
            <dt class="col-sm-4">Prezime</dt><dd class="col-sm-8">@Model.Prezime</dd>
            <dt class="col-sm-4">JMBG</dt><dd class="col-sm-8"><span class="badge bg-secondary">@Model.JMBG</span></dd>
            <dt class="col-sm-4">Telefon</dt><dd class="col-sm-8">@Model.Telefon</dd>
            <dt class="col-sm-4">Email</dt><dd class="col-sm-8">@Model.Email</dd>
            <dt class="col-sm-4">Datum Registracije</dt><dd class="col-sm-8">@Model.DatumRegistracije.ToLongDateString()</dd>
        </dl></div></div></div>
    </div>
    <div class="mt-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Izmeni</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Obriši</a>
        <a asp-action="Index" class="btn btn-secondary">Nazad</a>
    </div>
</div>
