@model PvcStolarija.MVC.ViewModels.Kupac.KupacViewModel
@{ ViewData["Title"] = "Detalji Kupca"; }

<div class="page-header">
    <h2><i class="bi bi-person me-2"></i>Detalji Kupca</h2>
</div>

<div class="row">
    <div class="col-md-3 text-center mb-4">
        @if (!string.IsNullOrEmpty(Model.ProfilnaSlika))
        {
            <img src="@Model.ProfilnaSlika" class="img-fluid rounded-circle shadow" style="width:180px;height:180px;object-fit:cover;" />
        }
        else
        {
            <div class="avatar-initials mx-auto" style="width:120px;height:120px;font-size:2.5rem;">
                @Model.Ime.Substring(0,1)@Model.Prezime.Substring(0,1)
            </div>
        }
        <h5 class="mt-3">@Model.Ime @Model.Prezime</h5>
    </div>
    <div class="col-md-9">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white"><h6 class="mb-0"><i class="bi bi-info-circle me-2"></i>Podaci o Kupcu</h6></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Ime</dt><dd class="col-sm-8">@Model.Ime</dd>
                    <dt class="col-sm-4 text-muted">Prezime</dt><dd class="col-sm-8">@Model.Prezime</dd>
                    <dt class="col-sm-4 text-muted">JMBG</dt><dd class="col-sm-8"><code>@Model.JMBG</code></dd>
                    <dt class="col-sm-4 text-muted">Telefon</dt><dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Telefon) ? "—" : Model.Telefon)</dd>
                    <dt class="col-sm-4 text-muted">Email</dt><dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Email) ? "—" : Model.Email)</dd>
                    <dt class="col-sm-4 text-muted">Datum Registracije</dt><dd class="col-sm-8">@Model.DatumRegistracije.ToLongDateString()</dd>
                </dl>
            </div>
        </div>
        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Izmeni</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Obriši</a>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i>Nazad</a>
        </div>
    </div>
</div>
