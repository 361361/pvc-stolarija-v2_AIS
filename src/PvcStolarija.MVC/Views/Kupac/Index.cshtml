@model IEnumerable<PvcStolarija.MVC.ViewModels.Kupac.KupacViewModel>
@{ ViewData["Title"] = "Lista Kupaca"; }

<div class="page-header">
    <div>
        <h2><i class="bi bi-people me-2"></i>Lista Kupaca</h2>
        <small class="opacity-75">Ukupno: @Model.Count() kupaca</small>
    </div>
    <a asp-action="Create" class="btn btn-light btn-sm"><i class="bi bi-plus-circle me-1"></i>Dodaj Kupca</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th></th><th>Ime i Prezime</th><th>JMBG</th><th>Telefon</th><th>Email</th><th>Datum Registracije</th><th>Akcije</th></tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center py-4 text-muted"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Nema kupaca u bazi.</td></tr>
                    }
                    @foreach (var k in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(k.ProfilnaSlika))
                                {
                                    <img src="@k.ProfilnaSlika" class="rounded-circle" style="width:40px;height:40px;object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="avatar-initials">@k.Ime.Substring(0,1)@k.Prezime.Substring(0,1)</div>
                                }
                            </td>
                            <td class="fw-semibold">@k.Ime @k.Prezime</td>
                            <td><code>@k.JMBG</code></td>
                            <td>@k.Telefon</td>
                            <td>@k.Email</td>
                            <td>@k.DatumRegistracije.ToShortDateString()</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@k.Id" class="btn btn-outline-info btn-sm"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit"    asp-route-id="@k.Id" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete"  asp-route-id="@k.Id" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
