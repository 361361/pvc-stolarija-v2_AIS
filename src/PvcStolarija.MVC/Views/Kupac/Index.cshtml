@model IEnumerable<PvcStolarija.DAL.Models.Kupac>
@{ ViewData["Title"] = "Lista Kupaca"; }

    <h1 class="mb-4">Lista Kupaca</h1>
    <p><a asp-action="Create" class="btn btn-primary">Dodaj Novog Kupca</a></p>
    <table class="table table-striped table-hover"><thead class="table-dark">
        <tr><th>Slika</th><th>Ime</th><th>Prezime</th><th>JMBG</th><th>Telefon</th><th>Email</th><th>Datum Registracije</th><th>Akcije</th></tr>
    </thead><tbody>
        @if (Model.Any()) {
            @foreach (var k in Model) {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(k.ProfilnaSlika)) { <img src="@k.ProfilnaSlika" class="img-thumbnail" style="width:50px;height:50px;object-fit:cover;" /> }
                    else { <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="width:50px;height:50px;border-radius:4px;"><span>@k.Ime.Substring(0,1)@k.Prezime.Substring(0,1)</span></div> }
                </td>
                <td>@k.Ime</td><td>@k.Prezime</td><td>@k.JMBG</td><td>@k.Telefon</td><td>@k.Email</td>
                <td>@k.DatumRegistracije.ToShortDateString()</td>
                <td>
                    <a asp-action="Details" asp-route-id="@k.Id" class="btn btn-info btn-sm">Detalji</a>
                    <a asp-action="Edit" asp-route-id="@k.Id" class="btn btn-warning btn-sm">Izmeni</a>
                    <a asp-action="Delete" asp-route-id="@k.Id" class="btn btn-danger btn-sm">Obriši</a>
                </td>
            </tr>
            }
        } else { <tr><td colspan="8" class="text-center"><em>Nema kupaca u bazi.</em></td></tr> }
    </tbody></table>
</div>
