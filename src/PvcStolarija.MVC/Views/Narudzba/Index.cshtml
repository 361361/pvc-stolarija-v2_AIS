@model IEnumerable<PvcStolarija.MVC.ViewModels.Narudzba.NarudzbaViewModel>
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Lista Narudžbi"; }

<div class="page-header">
    <div>
        <h2><i class="bi bi-box-seam me-2"></i>Lista Narudžbi</h2>
        <small class="opacity-75">Ukupno: @Model.Count() narudžbi</small>
    </div>
    <a asp-action="Create" class="btn btn-light btn-sm"><i class="bi bi-plus-circle me-1"></i>Nova Narudžba</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>Broj</th><th>Tip</th><th>Datum</th><th>Radnik</th><th>Proizvod</th><th>Kupci</th><th>Akcije</th></tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center py-4 text-muted"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Nema narudžbi u bazi.</td></tr>
                    }
                    @foreach (var n in Model)
                    {
                        <tr>
                            <td><span class="badge bg-primary fs-6">#@n.BrojNarudzbe</span></td>
                            <td>
                                @if (n.TipNarudzbe == TipNarudzbe.Online)
                                { <span class="badge bg-info">Online</span> }
                                else
                                { <span class="badge bg-success">Lično</span> }
                            </td>
                            <td>@(n.Datum.HasValue ? n.Datum.Value.ToString("dd.MM.yyyy") : "—")</td>
                            <td>@(n.RadnikImePrezime ?? "—")</td>
                            <td>@(n.ProizvodNaziv ?? "—")</td>
                            <td><span class="badge bg-warning text-dark">@n.KupacNarudzbine.Count</span></td>
                            <td>
                                <a asp-action="Details" asp-route-id="@n.Id" class="btn btn-outline-info btn-sm"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit"    asp-route-id="@n.Id" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete"  asp-route-id="@n.Id" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
