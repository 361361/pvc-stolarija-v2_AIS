@model IEnumerable<PvcStolarija.DAL.Models.Narudzba>
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Lista Narudžbi"; }

    <h1 class="mb-4">Lista Narudžbi</h1>
    <p><a asp-action="Create" class="btn btn-primary">Dodaj Novu Narudžbu</a></p>
    <table class="table table-striped table-hover"><thead class="table-dark">
        <tr><th>Broj</th><th>Tip</th><th>Datum</th><th>Radnik</th><th>Proizvod</th><th>Kupci</th><th>Akcije</th></tr>
    </thead><tbody>
        @if (Model.Any()) {
            @foreach (var n in Model) {
            <tr>
                <td><span class="badge bg-primary fs-6">Narudžba #@n.BrojNarudzbe</span></td>
                <td>@if(n.TipNarudzbe==TipNarudzbe.Online){<span class="badge bg-info">Online</span>}else{<span class="badge bg-success">Lično</span>}</td>
                <td>@(n.Datum.HasValue ? n.Datum.Value.ToString("dd.MM.yyyy") : "-")</td>
                <td>@(n.Radnik!=null ? $"{n.Radnik.Ime} {n.Radnik.Prezime}" : "-")</td>
                <td>@(n.Proizvod!=null ? n.Proizvod.NazivProizvoda : "-")</td>
                <td><span class="badge bg-warning text-dark">@(n.KupacNarudzbine?.Count ?? 0)</span></td>
                <td>
                    <a asp-action="Details" asp-route-id="@n.Id" class="btn btn-info btn-sm">Detalji</a>
                    <a asp-action="Edit" asp-route-id="@n.Id" class="btn btn-warning btn-sm">Izmeni</a>
                    <a asp-action="Delete" asp-route-id="@n.Id" class="btn btn-danger btn-sm">Obriši</a>
                </td>
            </tr>
            }
        } else { <tr><td colspan="7" class="text-center"><em>Nema narudžbi u bazi.</em></td></tr> }
    </tbody></table>
</div>
