@model PvcStolarija.DAL.Models.Narudzba
@{ ViewData["Title"] = "Obriši Narudžbu"; }
<div>
    <div class="page-header mb-4" style="background:linear-gradient(135deg,#dc3545,#b02a37)"><h2>Obriši Narudžbu</h1>
    <div class="alert alert-warning"><strong>Upozorenje!</strong> Da li ste sigurni da želite obrisati ovu narudžbu?</div>
    <div class="card"><div class="card-header bg-danger text-white"><h5 class="mb-0">Podaci narudžbe</h5></div>
    <div class="card-body"><dl class="row">
        <dt class="col-sm-4">Broj</dt><dd class="col-sm-8">#@Model.BrojNarudzbe</dd>
        <dt class="col-sm-4">Tip</dt><dd class="col-sm-8">@Model.TipNarudzbe</dd>
        <dt class="col-sm-4">Datum</dt><dd class="col-sm-8">@(Model.Datum.HasValue?Model.Datum.Value.ToString("dd.MM.yyyy"):"-")</dd>
        <dt class="col-sm-4">Kupci</dt><dd class="col-sm-8">@(Model.KupacNarudzbine?.Count ?? 0)</dd>
    </dl></div></div>
    <form asp-action="Delete" method="post" class="mt-3"><input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Potvrdi Brisanje</button>
        <a asp-action="Index" class="btn btn-secondary">Odustani</a>
    </form>
</div>
