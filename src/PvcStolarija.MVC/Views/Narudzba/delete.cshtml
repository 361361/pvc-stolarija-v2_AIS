@model PvcStolarija.MVC.ViewModels.Narudzba.NarudzbaViewModel
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Obriši Narudžbu"; }

<div class="page-header" style="background:linear-gradient(135deg,#dc3545,#b02a37)">
    <h2><i class="bi bi-trash me-2"></i>Obriši Narudžbu</h2>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-2"></i><strong>Upozorenje!</strong> Ova akcija je trajna.</div>
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white"><h6 class="mb-0">Podaci narudžbe koja se briše</h6></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Broj</dt><dd class="col-sm-8">#@Model.BrojNarudzbe</dd>
                    <dt class="col-sm-4 text-muted">Tip</dt><dd class="col-sm-8">@Model.TipNarudzbe</dd>
                    <dt class="col-sm-4 text-muted">Datum</dt><dd class="col-sm-8">@(Model.Datum.HasValue ? Model.Datum.Value.ToString("dd.MM.yyyy") : "—")</dd>
                    <dt class="col-sm-4 text-muted">Kupci</dt><dd class="col-sm-8">@Model.KupacNarudzbine.Count</dd>
                </dl>
            </div>
        </div>
        <form asp-action="Delete" method="post" class="mt-3">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Potvrdi Brisanje</button>
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x me-1"></i>Odustani</a>
            </div>
        </form>
    </div>
</div>
