@model PvcStolarija.MVC.ViewModels.Narudzba.NarudzbaViewModel
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Nova Narudžba"; }

<div class="page-header">
    <h2><i class="bi bi-box-seam me-2"></i>Nova Narudžba</h2>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label asp-for="BrojNarudzbe" class="form-label">Broj Narudžbe <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-hash"></i></span>
                                <input asp-for="BrojNarudzbe" class="form-control" type="number" min="1" />
                            </div>
                            <span asp-validation-for="BrojNarudzbe" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="TipNarudzbe" class="form-label">Tip <span class="text-danger">*</span></label>
                            <select asp-for="TipNarudzbe" class="form-select" asp-items="Html.GetEnumSelectList<TipNarudzbe>()">
                                <option value="">-- Izaberi --</option>
                            </select>
                            <span asp-validation-for="TipNarudzbe" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Datum" class="form-label">Datum</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-calendar"></i></span>
                                <input asp-for="Datum" class="form-control" type="date" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RadnikId" class="form-label">Odgovorni Radnik</label>
                            <select asp-for="RadnikId" class="form-select">
                                <option value="">-- Izaberi Radnika --</option>
                                @foreach (var r in Model.RadniciLista)
                                {
                                    <option value="@r.Id">@r.ImePrezime</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProizvodId" class="form-label">Naručeni Proizvod</label>
                            <select asp-for="ProizvodId" class="form-select">
                                <option value="">-- Izaberi Proizvod --</option>
                                @foreach (var p in Model.ProizvodiLista)
                                {
                                    <option value="@p.Id">@p.Naziv</option>
                                }
                            </select>
                            <small class="text-muted">Prikazani su samo dostupni proizvodi</small>
                        </div>
                    </div>

                    <hr />
                    <h6 class="fw-semibold mb-3 text-muted"><i class="bi bi-people me-1"></i>Kupci na Narudžbi</h6>
                    <div class="card bg-light">
                        <div class="card-body" style="max-height:350px;overflow-y:auto;">
                            @if (Model.SviKupci.Any())
                            {
                                <div class="row g-2">
                                    @foreach (var k in Model.SviKupci)
                                    {
                                        <div class="col-md-6">
                                            <div class="form-check p-2 border rounded bg-white">
                                                <input class="form-check-input" type="checkbox" name="SelectedKupciIds" value="@k.Id" id="k_@k.Id" />
                                                <label class="form-check-label" for="k_@k.Id">
                                                    <strong>@k.ImePrezime</strong><br/>
                                                    <small class="text-muted">@k.JMBG</small>
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else { <p class="text-muted mb-0">Nema kupaca u bazi.</p> }
                        </div>
                    </div>

                    <hr />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Sačuvaj</button>
                        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x me-1"></i>Otkaži</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
