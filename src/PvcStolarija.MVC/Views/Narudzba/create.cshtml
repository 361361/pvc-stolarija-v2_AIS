@model PvcStolarija.DAL.Models.Narudzba
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Dodaj Narudžbu"; }
<div>
    <div class="page-header mb-4"><h2>Dodaj Novu Narudžbu</h1><hr />
    <div class="row"><div class="col-md-8">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="row">
                <div class="col-md-6 mb-3"><label asp-for="BrojNarudzbe" class="form-label">Broj Narudžbe *</label><input asp-for="BrojNarudzbe" class="form-control" type="number" min="1" /></div>
                <div class="col-md-6 mb-3"><label asp-for="TipNarudzbe" class="form-label">Tip Narudžbe *</label>
                    <select asp-for="TipNarudzbe" class="form-control" asp-items="Html.GetEnumSelectList<TipNarudzbe>()"><option value="">-- Izaberi --</option></select></div>
            </div>
            <div class="mb-3"><label asp-for="Datum" class="form-label">Datum</label><input asp-for="Datum" class="form-control" type="date" /><small class="text-muted">Opciono</small></div>
            <div class="row">
                <div class="col-md-6 mb-3"><label asp-for="RadnikId" class="form-label">Odgovorni Radnik</label>
                    <select asp-for="RadnikId" class="form-control">
                        <option value="">-- Izaberi Radnika --</option>
                        @if(ViewBag.RadniciLista!=null){@foreach(var r in (List<Radnik>)ViewBag.RadniciLista){<option value="@r.Id">@r.Ime @r.Prezime</option>}}
                    </select></div>
                <div class="col-md-6 mb-3"><label asp-for="ProizvodId" class="form-label">Naručeni Proizvod</label>
                    <select asp-for="ProizvodId" class="form-control">
                        <option value="">-- Izaberi Proizvod --</option>
                        @if(ViewBag.ProizvodiLista!=null){@foreach(var p in (List<Proizvod>)ViewBag.ProizvodiLista){<option value="@p.Id">@p.Naziv @p.Model (@p.Sifra)</option>}}
                    </select><small class="text-muted">Prikazani su samo dostupni proizvodi</small></div>
            </div>
            <hr /><h5 class="mb-3">Kupci na Narudžbi</h5>
            <div class="card"><div class="card-body" style="max-height:400px;overflow-y:auto;">
                @if(ViewBag.Kupci!=null&&((IEnumerable<Kupac>)ViewBag.Kupci).Any()){
                <div class="row">
                    @foreach(var k in (IEnumerable<Kupac>)ViewBag.Kupci){
                    <div class="col-md-6 mb-2"><div class="form-check">
                        <input class="form-check-input" type="checkbox" name="selectedKupci" value="@k.Id" id="kupac_@k.Id" />
                        <label class="form-check-label" for="kupac_@k.Id">@k.Ime @k.Prezime <small class="text-muted">(@k.JMBG)</small></label>
                    </div></div>
                    }
                </div>
                } else { <p class="text-muted mb-0">Nema kupaca u bazi.</p> }
            </div></div>
            <div class="mt-4"><button type="submit" class="btn btn-success">Sačuvaj</button> <a asp-action="Index" class="btn btn-secondary">Nazad</a></div>
        </form>
    </div></div>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
