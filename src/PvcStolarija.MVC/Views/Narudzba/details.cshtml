@model PvcStolarija.MVC.ViewModels.Narudzba.NarudzbaViewModel
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Detalji Narudžbe"; }

<div class="page-header">
    <h2><i class="bi bi-box-seam me-2"></i>Narudžba #@Model.BrojNarudzbe</h2>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-dark text-white"><h6 class="mb-0">Osnovne Informacije</h6></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Broj</dt><dd class="col-sm-8"><span class="badge bg-primary fs-6">#@Model.BrojNarudzbe</span></dd>
                    <dt class="col-sm-4 text-muted">Tip</dt>
                    <dd class="col-sm-8">
                        @if (Model.TipNarudzbe == TipNarudzbe.Online)
                        { <span class="badge bg-info">Online</span> }
                        else
                        { <span class="badge bg-success">Lično</span> }
                    </dd>
                    <dt class="col-sm-4 text-muted">Datum</dt><dd class="col-sm-8">@(Model.Datum.HasValue ? Model.Datum.Value.ToString("dd.MM.yyyy") : "—")</dd>
                    <dt class="col-sm-4 text-muted">Radnik</dt><dd class="col-sm-8">@(Model.RadnikImePrezime ?? "—")</dd>
                    <dt class="col-sm-4 text-muted">Proizvod</dt><dd class="col-sm-8">@(Model.ProizvodNaziv ?? "—")</dd>
                </dl>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-warning"><h6 class="mb-0"><i class="bi bi-people me-2"></i>Kupci (@Model.KupacNarudzbine.Count)</h6></div>
            <div class="card-body p-0">
                @if (Model.KupacNarudzbine.Any())
                {
                    <table class="table table-hover mb-0">
                        <thead><tr><th>Kupac</th><th>Potvrđeno</th><th>Napomena</th></tr></thead>
                        <tbody>
                            @foreach (var kn in Model.KupacNarudzbine)
                            {
                                <tr>
                                    <td>@kn.KupacImePrezime</td>
                                    <td>
                                        @if (kn.Potvrdjen)
                                        { <span class="badge bg-success"><i class="bi bi-check me-1"></i>Da</span> }
                                        else
                                        { <span class="badge bg-secondary"><i class="bi bi-x me-1"></i>Ne</span> }
                                    </td>
                                    <td>@(string.IsNullOrEmpty(kn.Napomena) ? "—" : kn.Napomena)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else { <p class="text-muted p-3 mb-0">Nema kupaca.</p> }
            </div>
        </div>

        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Izmeni</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Obriši</a>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i>Nazad</a>
        </div>
    </div>
</div>
