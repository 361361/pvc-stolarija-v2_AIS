@model PvcStolarija.MVC.ViewModels.Proizvod.ProizvodViewModel
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Izmeni Proizvod"; }

<div class="page-header">
    <h2><i class="bi bi-pencil-square me-2"></i>Izmeni Proizvod</h2>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Naziv" class="form-label">Naziv <span class="text-danger">*</span></label>
                            <input asp-for="Naziv" class="form-control" />
                            <span asp-validation-for="Naziv" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Model" class="form-label">Model <span class="text-danger">*</span></label>
                            <input asp-for="Model" class="form-control" />
                            <span asp-validation-for="Model" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Sifra" class="form-label">Šifra <span class="text-danger">*</span></label>
                            <input asp-for="Sifra" class="form-control" maxlength="20" />
                            <span asp-validation-for="Sifra" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="TipMaterijala" class="form-label">Tip Materijala <span class="text-danger">*</span></label>
                            <select asp-for="TipMaterijala" class="form-select" asp-items="Html.GetEnumSelectList<TipMaterijala>()"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Dostupnost" class="form-label">Dostupnost <span class="text-danger">*</span></label>
                            <select asp-for="Dostupnost" class="form-select" asp-items="Html.GetEnumSelectList<Dostupnost>()"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="GodinaProizvodnje" class="form-label">Godina</label>
                            <input asp-for="GodinaProizvodnje" class="form-control" type="number" />
                        </div>
                    </div>

                    <hr />
                    <h6 class="fw-semibold mb-3 text-muted"><i class="bi bi-images me-1"></i>Postojeće Slike</h6>
                    @if (Model.Slike.Any())
                    {
                        <div class="row g-3 mb-3">
                            @foreach (var s in Model.Slike)
                            {
                                <div class="col-md-3" id="slika-@s.Id">
                                    <div class="card h-100">
                                        <img src="@s.PutanjaDoSlike" class="card-img-top" style="height:120px;object-fit:cover;" />
                                        <div class="card-body p-2">
                                            @if (!string.IsNullOrEmpty(s.Opis)) { <p class="small text-muted mb-1">@s.Opis</p> }
                                            <button type="button" class="btn btn-danger btn-sm w-100" onclick="deleteImage(@s.Id)">
                                                <i class="bi bi-trash me-1"></i>Obriši
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else { <p class="text-muted small">Nema slika.</p> }

                    <h6 class="fw-semibold mb-3 text-muted mt-3"><i class="bi bi-cloud-upload me-1"></i>Dodaj Nove Slike</h6>
                    <div id="noveSlikeContainer">
                        <div class="slika-row mb-3 p-3 border rounded">
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <input type="file" name="NoveSlike" class="form-control form-control-sm" accept="image/*" onchange="previewImage(this)" />
                                </div>
                                <div class="col-md-5">
                                    <input type="text" name="OpisiNovihSlika" class="form-control form-control-sm" placeholder="Opis (opciono)" />
                                </div>
                                <div class="col-md-1 d-flex align-items-end">
                                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeRow(this)" style="display:none;"><i class="bi bi-x"></i></button>
                                </div>
                            </div>
                            <img class="preview-img mt-2 img-thumbnail" style="max-height:120px;display:none;" />
                        </div>
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm mb-3" onclick="addRow()">
                        <i class="bi bi-plus me-1"></i>Dodaj Još Slika
                    </button>

                    <hr />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Sačuvaj Izmene</button>
                        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x me-1"></i>Otkaži</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function addRow() {
            const c = document.getElementById('noveSlikeContainer');
            const n = c.querySelector('.slika-row').cloneNode(true);
            n.querySelector('input[type="file"]').value = '';
            n.querySelector('input[type="text"]').value = '';
            n.querySelector('.preview-img').style.display = 'none';
            n.querySelector('button').style.display = 'inline-block';
            c.appendChild(n);
        }
        function removeRow(b) { b.closest('.slika-row').remove(); }
        function previewImage(i) {
            const p = i.closest('.slika-row').querySelector('.preview-img');
            if (i.files && i.files[0]) {
                const r = new FileReader();
                r.onload = e => { p.src = e.target.result; p.style.display = 'block'; };
                r.readAsDataURL(i.files[0]);
            }
        }
        function deleteImage(id) {
            if (!confirm('Obrisati sliku?')) return;
            fetch('/Proizvod/DeleteImage/' + id, { method: 'POST' })
                .then(r => r.json())
                .then(d => { if (d.success) document.getElementById('slika-' + id).remove(); else alert('Greška: ' + d.message); });
        }
    </script>
}
