@model PvcStolarija.DAL.Models.Proizvod
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Obriši Proizvod"; }
<div>
    <div class="page-header mb-4" style="background:linear-gradient(135deg,#dc3545,#b02a37)"><h2>Obriši Proizvod</h1>
    <div class="alert alert-warning">
        <strong>Upozorenje!</strong> Da li ste sigurni da želite obrisati ovaj proizvod?
        @if (Model.Slike?.Any() == true)
        {
            <br />
            <strong>Napomena:</strong>
            <text>Bice obrisano i </text>@Model.Slike.Count<text> slika.</text>
        }
    </div>
    <div class="row"><div class="col-md-8">
        <div class="card"><div class="card-header bg-danger text-white"><h5 class="mb-0">Podaci proizvoda</h5></div>
        <div class="card-body"><dl class="row">
            <dt class="col-sm-4">Naziv</dt><dd class="col-sm-8">@Model.Naziv</dd>
            <dt class="col-sm-4">Model</dt><dd class="col-sm-8">@Model.Model</dd>
            <dt class="col-sm-4">Šifra</dt><dd class="col-sm-8">@Model.Sifra</dd>
            <dt class="col-sm-4">Tip Materijala</dt><dd class="col-sm-8">@Model.TipMaterijala</dd>
            <dt class="col-sm-4">Dostupnost</dt><dd class="col-sm-8">@Model.Dostupnost</dd>
        </dl></div></div>
    </div></div>
    <form asp-action="Delete" method="post" class="mt-3"><input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Potvrdi Brisanje</button>
        <a asp-action="Index" class="btn btn-secondary">Odustani</a>
    </form>
</div>
