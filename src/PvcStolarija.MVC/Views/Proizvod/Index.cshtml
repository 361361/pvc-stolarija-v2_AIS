@model IEnumerable<PvcStolarija.DAL.Models.Proizvod>
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Lista Proizvoda"; }

    <h1 class="mb-4">Lista Proizvoda</h1>
    <p><a asp-action="Create" class="btn btn-primary">Dodaj Novi Proizvod</a></p>
    <table class="table table-striped table-hover"><thead class="table-dark">
        <tr><th>Slike</th><th>Naziv</th><th>Model</th><th>Šifra</th><th>Godina</th><th>Tip Materijala</th><th>Dostupnost</th><th>Akcije</th></tr>
    </thead><tbody>
        @if (Model.Any()) {
            @foreach (var p in Model) {
            <tr>
                <td>
                    @if (p.Slike?.Any() == true) {
                        <img src="@p.Slike.First().PutanjaDoSlike" class="img-thumbnail" style="width:60px;height:60px;object-fit:cover;" />
                        @if (p.Slike.Count > 1) { <span class="badge bg-info">+@(p.Slike.Count-1)</span> }
                    } else { <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="width:60px;height:60px;">🪟</div> }
                </td>
                <td>@p.Naziv</td><td>@p.Model</td>
                <td><span class="badge bg-primary">@p.Sifra</span></td>
                <td>@p.GodinaProizvodnje</td>
                <td>
                    @switch(p.TipMaterijala) {
                        case TipMaterijala.PVC: <span class="badge bg-primary">PVC</span> break;
                        case TipMaterijala.Aluminijum: <span class="badge bg-dark">Aluminijum</span> break;
                        case TipMaterijala.Drvo: <span class="badge bg-warning text-dark">Drvo</span> break;
                    }
                </td>
                <td>
                    @if (p.Dostupnost == Dostupnost.Dostupan) { <span class="badge bg-success">Dostupan</span> }
                    else { <span class="badge bg-danger">Nedostupan</span> }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-info btn-sm">Detalji</a>
                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-warning btn-sm">Izmeni</a>
                    <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-danger btn-sm">Obriši</a>
                </td>
            </tr>
            }
        } else { <tr><td colspan="8" class="text-center"><em>Nema proizvoda u bazi.</em></td></tr> }
    </tbody></table>
</div>
