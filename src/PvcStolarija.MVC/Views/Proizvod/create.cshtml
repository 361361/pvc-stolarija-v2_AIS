@model PvcStolarija.MVC.ViewModels.Proizvod.ProizvodViewModel
@using PvcStolarija.DAL.Models
@{ ViewData["Title"] = "Dodaj Proizvod"; }

<div class="page-header">
    <h2><i class="bi bi-plus-circle me-2"></i>Dodaj Novi Proizvod</h2>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <h6 class="fw-semibold mb-3 text-muted"><i class="bi bi-info-circle me-1"></i>Osnovni Podaci</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Naziv" class="form-label">Naziv <span class="text-danger">*</span></label>
                            <input asp-for="Naziv" class="form-control" placeholder="Npr. PVC Prozor" />
                            <span asp-validation-for="Naziv" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Model" class="form-label">Model <span class="text-danger">*</span></label>
                            <input asp-for="Model" class="form-control" placeholder="Npr. Jednokrilni 60x90" />
                            <span asp-validation-for="Model" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Sifra" class="form-label">Šifra <span class="text-danger">*</span></label>
                            <input asp-for="Sifra" class="form-control" placeholder="PRZ-001" maxlength="20" />
                            <span asp-validation-for="Sifra" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="TipMaterijala" class="form-label">Tip Materijala <span class="text-danger">*</span></label>
                            <select asp-for="TipMaterijala" class="form-select" asp-items="Html.GetEnumSelectList<TipMaterijala>()">
                                <option value="">-- Izaberi --</option>
                            </select>
                            <span asp-validation-for="TipMaterijala" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Dostupnost" class="form-label">Dostupnost <span class="text-danger">*</span></label>
                            <select asp-for="Dostupnost" class="form-select" asp-items="Html.GetEnumSelectList<Dostupnost>()">
                                <option value="">-- Izaberi --</option>
                            </select>
                            <span asp-validation-for="Dostupnost" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="GodinaProizvodnje" class="form-label">Godina Proizvodnje</label>
                            <input asp-for="GodinaProizvodnje" class="form-control" type="number" min="1990" max="@DateTime.Now.Year" />
                        </div>
                    </div>

                    <hr />
                    <h6 class="fw-semibold mb-3 text-muted"><i class="bi bi-images me-1"></i>Slike Proizvoda</h6>
                    <div id="slikeContainer">
                        <div class="slika-row mb-3 p-3 border rounded">
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label class="form-label small text-muted">Slika</label>
                                    <input type="file" name="NoveSlike" class="form-control form-control-sm" accept="image/*" onchange="previewImage(this)" />
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label small text-muted">Opis (opciono)</label>
                                    <input type="text" name="OpisiNovihSlika" class="form-control form-control-sm" placeholder="Npr. Prednja strana" />
                                </div>
                                <div class="col-md-1 d-flex align-items-end">
                                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeRow(this)" style="display:none;"><i class="bi bi-x"></i></button>
                                </div>
                            </div>
                            <img class="preview-img mt-2 img-thumbnail" style="max-height:120px;display:none;" />
                        </div>
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm mb-3" onclick="addRow()">
                        <i class="bi bi-plus me-1"></i>Dodaj Još Slika
                    </button>

                    <hr />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Sačuvaj</button>
                        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x me-1"></i>Otkaži</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function addRow() {
            const c = document.getElementById('slikeContainer');
            const n = c.querySelector('.slika-row').cloneNode(true);
            n.querySelector('input[type="file"]').value = '';
            n.querySelector('input[type="text"]').value = '';
            n.querySelector('.preview-img').style.display = 'none';
            n.querySelector('button').style.display = 'inline-block';
            c.appendChild(n);
        }
        function removeRow(b) { b.closest('.slika-row').remove(); }
        function previewImage(i) {
            const p = i.closest('.slika-row').querySelector('.preview-img');
            if (i.files && i.files[0]) {
                const r = new FileReader();
                r.onload = e => { p.src = e.target.result; p.style.display = 'block'; };
                r.readAsDataURL(i.files[0]);
            }
        }
    </script>
}
