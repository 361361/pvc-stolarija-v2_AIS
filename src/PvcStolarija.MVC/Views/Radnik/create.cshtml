@model PvcStolarija.MVC.ViewModels.Radnik.RadnikViewModel
@{ ViewData["Title"] = "Dodaj Radnika"; }

<div class="page-header">
    <h2><i class="bi bi-person-plus me-2"></i>Dodaj Novog Radnika</h2>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <h6 class="fw-semibold mb-3 text-muted"><i class="bi bi-info-circle me-1"></i>Lični Podaci</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Ime" class="form-label">Ime <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input asp-for="Ime" class="form-control" placeholder="Unesite ime" />
                            </div>
                            <span asp-validation-for="Ime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Prezime" class="form-label">Prezime <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input asp-for="Prezime" class="form-control" placeholder="Unesite prezime" />
                            </div>
                            <span asp-validation-for="Prezime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="JMBG" class="form-label">JMBG <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-credit-card"></i></span>
                                <input asp-for="JMBG" class="form-control" maxlength="13" placeholder="13 cifara" />
                            </div>
                            <span asp-validation-for="JMBG" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="GodineRadnogIskustva" class="form-label">God. Iskustva <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-award"></i></span>
                                <input asp-for="GodineRadnogIskustva" class="form-control" type="number" min="0" max="50" />
                            </div>
                            <span asp-validation-for="GodineRadnogIskustva" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr />
                    <h6 class="fw-semibold mb-3 text-muted"><i class="bi bi-telephone me-1"></i>Kontakt i Ugovor</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Telefon" class="form-label">Telefon</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                <input asp-for="Telefon" class="form-control" placeholder="+381..." />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Email" class="form-control" type="email" placeholder="email@primer.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BrojUgovora" class="form-label">Broj Ugovora</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-file-text"></i></span>
                                <input asp-for="BrojUgovora" class="form-control" placeholder="Opciono" />
                            </div>
                        </div>
                    </div>

                    <hr />
                    <h6 class="fw-semibold mb-3 text-muted"><i class="bi bi-image me-1"></i>Profilna Slika</h6>
                    <div class="mb-3">
                        <input asp-for="ProfilnaSlikaFajl" type="file" class="form-control" accept="image/*" onchange="previewImage(event)" />
                        <small class="text-muted">JPG, PNG, GIF — max 5MB (opciono)</small>
                    </div>
                    <div class="mb-3">
                        <img id="imagePreview" src="#" style="max-width:150px;max-height:150px;display:none;border-radius:8px;" class="border" />
                    </div>

                    <hr />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Sačuvaj</button>
                        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x me-1"></i>Otkaži</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="alert alert-info">
            <h6><i class="bi bi-info-circle me-1"></i>Napomena</h6>
            <ul class="small mb-0">
                <li>Polja označena sa <span class="text-danger">*</span> su obavezna</li>
                <li>JMBG mora imati tačno 13 cifara</li>
                <li>Profilna slika je opciona</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function previewImage(e) {
            const r = new FileReader();
            r.onload = () => { const o = document.getElementById('imagePreview'); o.src = r.result; o.style.display = 'block'; };
            r.readAsDataURL(e.target.files[0]);
        }
    </script>
}
