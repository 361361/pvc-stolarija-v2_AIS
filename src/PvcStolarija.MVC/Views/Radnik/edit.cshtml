@model PvcStolarija.MVC.ViewModels.Radnik.RadnikViewModel
@{ ViewData["Title"] = "Izmeni Radnika"; }

<div class="page-header">
    <h2><i class="bi bi-pencil-square me-2"></i>Izmeni Radnika</h2>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ProfilnaSlika" />

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Ime" class="form-label">Ime <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input asp-for="Ime" class="form-control" />
                            </div>
                            <span asp-validation-for="Ime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Prezime" class="form-label">Prezime <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input asp-for="Prezime" class="form-control" />
                            </div>
                            <span asp-validation-for="Prezime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="JMBG" class="form-label">JMBG <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-credit-card"></i></span>
                                <input asp-for="JMBG" class="form-control" maxlength="13" />
                            </div>
                            <span asp-validation-for="JMBG" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="GodineRadnogIskustva" class="form-label">God. Iskustva <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-award"></i></span>
                                <input asp-for="GodineRadnogIskustva" class="form-control" type="number" min="0" max="50" />
                            </div>
                            <span asp-validation-for="GodineRadnogIskustva" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Telefon" class="form-label">Telefon</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                <input asp-for="Telefon" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Email" class="form-control" type="email" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BrojUgovora" class="form-label">Broj Ugovora</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-file-text"></i></span>
                                <input asp-for="BrojUgovora" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <hr />
                    <h6 class="fw-semibold mb-2 text-muted"><i class="bi bi-image me-1"></i>Profilna Slika</h6>
                    @if (!string.IsNullOrEmpty(Model.ProfilnaSlika))
                    {
                        <div class="mb-2">
                            <img src="@Model.ProfilnaSlika" class="img-thumbnail" style="max-width:150px;max-height:150px;" />
                        </div>
                    }
                    <div class="mb-3">
                        <input asp-for="ProfilnaSlikaFajl" type="file" class="form-control" accept="image/*" onchange="previewImage(event)" />
                        <small class="text-muted">Ostavite prazno ako ne menjate sliku</small>
                    </div>
                    <img id="imagePreview" src="#" style="max-width:150px;max-height:150px;display:none;border-radius:8px;" class="border mb-3" />

                    <hr />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Sačuvaj Izmene</button>
                        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x me-1"></i>Otkaži</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function previewImage(e) {
            const r = new FileReader();
            r.onload = () => { const o = document.getElementById('imagePreview'); o.src = r.result; o.style.display = 'block'; };
            r.readAsDataURL(e.target.files[0]);
        }
    </script>
}
