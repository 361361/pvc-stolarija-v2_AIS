@model PvcStolarija.DAL.Models.Radnik
@{ ViewData["Title"] = "Obriši Radnika"; }
<div>
    <div class="page-header mb-4" style="background:linear-gradient(135deg,#dc3545,#b02a37)"><h2>Obriši Radnika</h1>
    <div class="alert alert-warning"><strong>Upozorenje!</strong> Da li ste sigurni da želite obrisati ovog radnika?</div>
    <div class="card"><div class="card-header bg-danger text-white"><h5 class="mb-0">Podaci radnika</h5></div>
    <div class="card-body"><dl class="row">
        <dt class="col-sm-3">Ime</dt><dd class="col-sm-9">@Model.Ime</dd>
        <dt class="col-sm-3">Prezime</dt><dd class="col-sm-9">@Model.Prezime</dd>
        <dt class="col-sm-3">JMBG</dt><dd class="col-sm-9">@Model.JMBG</dd>
        <dt class="col-sm-3">Ugovor</dt><dd class="col-sm-9">@(string.IsNullOrEmpty(Model.BrojUgovora)?"-":Model.BrojUgovora)</dd>
    </dl></div></div>
    <form asp-action="Delete" method="post" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Potvrdi Brisanje</button>
        <a asp-action="Index" class="btn btn-secondary">Odustani</a>
    </form>
</div>
