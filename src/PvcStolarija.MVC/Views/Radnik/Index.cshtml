@model IEnumerable<PvcStolarija.DAL.Models.Radnik>
@{ ViewData["Title"] = "Lista Radnika"; }

<div class="page-header">
    <div>
        <h2><i class="bi bi-person-badge me-2"></i>Lista Radnika</h2>
        <small class="opacity-75">Ukupno: @Model.Count() radnika</small>
    </div>
    <a asp-action="Create" class="btn btn-light btn-sm">
        <i class="bi bi-plus-circle me-1"></i>Dodaj Radnika
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th></th><th>Ime i Prezime</th><th>JMBG</th>
                        <th>Br. Ugovora</th><th>God. Iskustva</th>
                        <th>Telefon</th><th>Email</th><th>Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any()) {
                        <tr><td colspan="8" class="text-center py-4 text-muted"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Nema radnika u bazi.</td></tr>
                    }
                    @foreach (var r in Model) {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(r.ProfilnaSlika)) {
                                <img src="@r.ProfilnaSlika" class="rounded-circle" style="width:40px;height:40px;object-fit:cover;" />
                            } else {
                                <div class="avatar-initials">@r.Ime.Substring(0,1)@r.Prezime.Substring(0,1)</div>
                            }
                        </td>
                        <td class="fw-semibold">@r.Ime @r.Prezime</td>
                        <td><code>@r.JMBG</code></td>
                        <td>@(string.IsNullOrEmpty(r.BrojUgovora) ? "<span class='text-muted'>—</span>" : r.BrojUgovora)</td>
                        <td><span class="badge bg-success">@r.GodineRadnogIskustva god.</span></td>
                        <td>@r.Telefon</td>
                        <td>@r.Email</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-outline-info btn-sm"><i class="bi bi-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@r.Id" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
