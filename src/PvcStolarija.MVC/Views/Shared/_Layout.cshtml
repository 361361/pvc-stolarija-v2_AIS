<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PVC Stolarija</title>
    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold fs-5" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-fill me-1"></i> PVC Stolarija
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house me-1"></i>Početna
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Radnik" asp-action="Index">
                                <i class="bi bi-person-badge me-1"></i>Radnici
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Kupac" asp-action="Index">
                                <i class="bi bi-people me-1"></i>Kupci
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Proizvod" asp-action="Index">
                                <i class="bi bi-grid me-1"></i>Proizvodi
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Narudzba" asp-action="Index">
                                <i class="bi bi-box-seam me-1"></i>Narudžbe
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Reklamacija" asp-action="Index">
                                <i class="bi bi-exclamation-triangle me-1"></i>Reklamacije
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-1" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle"></i>
                                    <span>@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    @if (User.IsInRole("Administrator"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Account" asp-action="Register">
                                                <i class="bi bi-person-plus me-2"></i>Novi korisnik
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider" /></li>
                                    }
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right me-2"></i>Odjava
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Prijava
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4 mt-3">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <main role="main" class="pb-4">@RenderBody()</main>
    </div>

    <footer class="bg-dark text-white mt-5 py-3">
        <div class="container-fluid px-4">
            <div class="d-flex justify-content-between align-items-center">
                <span class="small"><i class="bi bi-house-fill me-1"></i> PVC Stolarija &mdash; Upravljanje radnicima, kupcima, proizvodima i reklamacijama</span>
                <span class="small">&copy; 2025 - PVC Stolarija - <a href="/Home/Privacy" class="text-white-50">Privacy</a></span>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS CDN -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
